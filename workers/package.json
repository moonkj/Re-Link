{
  "name": "relink-api",
  "version": "1.0.0",
  "description": "Re-Link Cloudflare Workers API — Family Plan sync server",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env development",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:init": "wrangler d1 execute relink-db --file=schema.sql",
    "db:init:dev": "wrangler d1 execute relink-db-dev --env development --local --file=schema.sql",
    "db:migrate": "wrangler d1 migrations apply relink-db",
    "db:console": "wrangler d1 execute relink-db --command='SELECT * FROM users LIMIT 10'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.101.0"
  },
  "dependencies": {}
}
