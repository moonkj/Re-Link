<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_preview"
    android:padding="14dp">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <!-- Family Stats (inline in header) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_stat_node_label"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/stat_node_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#06B6D4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_stat_memory_label"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/stat_memory_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#06B6D4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="3dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Divider ────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A3555"
        android:layout_marginBottom="10dp" />

    <!-- ── Content Row (Anniversary + Memory side by side) ────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ── Anniversary Section ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_anniversary_label"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <!-- Anniversary content -->
            <LinearLayout
                android:id="@+id/anniversary_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:id="@+id/anniversary_dday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="D-0"
                        android:textColor="#8B5CF6"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/anniversary_more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6B7280"
                        android:textSize="10sp"
                        android:layout_marginStart="6dp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/anniversary_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/anniversary_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Anniversary empty state -->
            <TextView
                android:id="@+id/anniversary_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_anniversary_empty"
                android:textColor="#4B5563"
                android:textSize="11sp"
                android:visibility="visible" />
        </LinearLayout>

        <!-- ── Vertical divider ───────────────────────────────────── -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A3555"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <!-- ── Today's Memory Section ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_memory_label"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <!-- Memory content -->
            <LinearLayout
                android:id="@+id/memory_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:id="@+id/memory_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/memory_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#06B6D4"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/memory_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Memory empty state -->
            <TextView
                android:id="@+id/memory_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_memory_empty"
                android:textColor="#4B5563"
                android:textSize="11sp"
                android:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
